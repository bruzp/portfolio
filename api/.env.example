APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Postgres runs in the "postgres" Docker service, not 127.0.0.1.
# Container-to-container communication uses the service name from docker-compose.yml.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=portfolio_db
DB_USERNAME=portfolio_user
DB_PASSWORD=portfolio_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# "log" only writes events to the log file — nothing actually broadcasts.
# Must be "reverb" so real-time events (notifications, etc.) reach connected clients.
BROADCAST_CONNECTION=reverb

# "local" stores files inside the container's disk, bypassing MinIO entirely.
# Must be "s3" so uploads go through MinIO (our local S3-compatible storage).
FILESYSTEM_DISK=s3

# "database" works but doesn't support Laravel Horizon, which requires Redis.
# Redis is also faster and already running as its own Docker service.
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis runs in the "redis" Docker service, not 127.0.0.1.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# "log" mailer just writes emails to storage/logs — nothing shows in Mailpit's UI.
# Mailpit's SMTP listens on port 1025, not 2525. Host is the "mailpit" Docker service.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# MinIO is our local S3-compatible storage, running as the "minio" Docker service.
# Credentials here must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose.yml.
AWS_ACCESS_KEY_ID=portfolio_minio
AWS_SECRET_ACCESS_KEY=portfolio_minio_secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=portfolio
# MinIO requires path-style URLs (host/bucket/file) instead of AWS's
# default virtual-hosted style (bucket.host/file). Must be "true".
AWS_USE_PATH_STYLE_ENDPOINT=true
# Only needed for S3-compatible services like MinIO — real AWS S3 doesn't need this.
AWS_ENDPOINT=http://minio:9000

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb — our self-hosted WebSocket server (replaces Pusher).
# Runs as its own "reverb" Docker service. App ID/key/secret are arbitrary
# local values, not real credentials — they just need to match between
# the server config and whatever client (Echo) connects to it.
REVERB_APP_ID=portfolio
REVERB_APP_KEY=portfolio_key
REVERB_APP_SECRET=portfolio_secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# These mirror the REVERB_* values above for any Vite/Echo client inside
# this Laravel app. Host is "localhost" here (not "reverb") because this
# is read by the *browser*, which connects from outside Docker's network.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="localhost"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
